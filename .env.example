# 서버 전용 (BFF → 외부 SlidTodo API). NEXT_PUBLIC_ 접두어 금지.
BACKEND_API_BASE_URL=https://slid-to-do-api.vercel.app
BACKEND_TEAM_ID=

# 라이브 통합 테스트 전용 (로컬 .env 에만, 커밋 금지). 미설정 시 라이브 테스트 skip.
BACKEND_TEST_EMAIL=
BACKEND_TEST_PASSWORD=

# 소셜 로그인 전용 클라이언트 ID 및 인가 코드 발급 후 리다이렉트 주소
# Google
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# Kakao
KAKAO_AUTH_CLIENT_ID=
KAKAO_AUTH_CLIENT_SECRET=

# NextAuth 전용 환경변수 설정
NEXTAUTH_SECRET=
NEXTAUTH_URL=
